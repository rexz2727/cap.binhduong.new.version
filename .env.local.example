# Sanity.io — lấy từ https://sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID="your_project_id_here"
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2024-01-01"
SANITY_API_READ_TOKEN="your_viewer_token_here"

# Resend — lấy từ https://resend.com/api-keys
RESEND_API_KEY="re_your_key_here"
CONTACT_EMAIL="cong-an-phuong-binh-duong@mail.gov.vn"

# Bảo vệ /studio (Basic Auth)
STUDIO_BASIC_USER="admin"
STUDIO_BASIC_PASS="change-this-strong-password"

# URL production (điền sau khi deploy Vercel)
NEXT_PUBLIC_SITE_URL="https://your-domain.vercel.app"
